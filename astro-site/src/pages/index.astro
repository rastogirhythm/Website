---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';
import { getCollection } from 'astro:content';

// Get featured projects (you can add a 'featured' field to frontmatter)
const projects = await getCollection('projects');
const featuredProjects = projects
  .filter(p => p.data.featured)
  .slice(0, 3);
---

<BaseLayout>
  <section class="hero">
    <!-- Featured Images - Static background -->
    <div class="hero-images">
      <img src="/Website/images/hero-bg.jpg" alt="Hero Background" class="hero-bg-image" />
    </div>
    
    <div class="hero-content">
      <!-- Name with elegant spacing -->
      <h1 class="hero-name">
        <span class="name-first"><em>rhythm</em></span>
        <span class="name-last">rastogi</span>
      </h1>
      
      <!-- Tagline -->
      <p class="hero-tagline">{site.tagline}</p>
      
      <!-- Location -->
      <p class="hero-location">{site.location}</p>
      
      <!-- Social Links -->
      <div class="hero-social">
        <a href={site.resume} target="_blank" rel="noopener noreferrer" class="social-link">resume↗</a>
        {site.social.map(({ label, url }) => (
          <a href={url} target="_blank" rel="noopener noreferrer" class="social-link">{label}↗</a>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Brief intro section -->
  <section class="intro">
    <div class="intro-content">
      <p class="intro-text">{site.bio}</p>
      <div class="intro-links">
        <a href={`${import.meta.env.BASE_URL}/about`} class="link">more about me</a>
        <a href={`${import.meta.env.BASE_URL}/projects`} class="link">view all projects</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero Section */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-xl);
    padding: var(--space-3xl) var(--space-2xl) var(--space-xl);
    align-items: center;
  }
  
  .hero-content {
    max-width: 500px;
    margin-left: auto;
  }
  
  .hero-name {
    font-size: var(--text-display);
    font-weight: 400;
    line-height: 0.95;
    margin-bottom: var(--space-lg);
  }
  
  .name-first {
    display: block;
    font-style: italic;
  }
  
  .name-last {
    display: block;
    letter-spacing: -0.02em;
  }
  
  .hero-tagline {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 380px;
    line-height: 1.6;
    margin-bottom: var(--space-md);
  }
  
  .hero-location {
    font-size: var(--text-sm);
    color: var(--color-text-subtle);
    letter-spacing: 0.02em;
    margin-bottom: var(--space-md);
  }
  
  .hero-social {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }
  
  .social-link {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  
  .social-link:hover {
    color: var(--color-accent);
  }
  
  /* Floating Images */
  .hero-images {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .hero-bg-image {
    width: 100%;
    height: auto;
    object-fit: contain;
    border-radius: 2px;
    transform: scale(1);
    max-width: 150%;
    margin-left: 20%;
  }
  
  /* Intro Section */
  .intro {
    padding: var(--space-3xl) var(--space-2xl);
    border-top: 1px solid var(--color-border);
  }
  
  .intro-content {
    max-width: var(--content-width);
    margin: 0 auto;
    text-align: center;
  }
  
  .intro-text {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }
  
  .intro-links {
    display: flex;
    justify-content: center;
    gap: var(--space-lg);
  }
  
  /* Mobile */
  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
      padding: var(--space-2xl) var(--space-lg) var(--space-xl);
      min-height: auto;
    }
    
    .hero-content {
      max-width: 100%;
      text-align: center;
      margin: 0 auto;
      order: -1;
    }
    
    .hero-tagline {
      margin: 0 auto var(--space-md);
    }
    
    .hero-images {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-md);
    }
    
    .pos-3 {
      grid-column: span 2;
      max-width: 60%;
      margin: 0 auto;
    }
    
    .scroll-hint {
      display: none;
    }
    
    .intro {
      padding: var(--space-3xl) var(--space-lg);
    }
  }
  
  @media (max-width: 640px) {
    .hero-name {
      font-size: var(--text-3xl);
    }
    
    .hero-images {
      grid-template-columns: 1fr;
    }
    
    .pos-3 {
      grid-column: span 1;
      max-width: 100%;
    }
  }
</style>
