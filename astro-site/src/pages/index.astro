---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';
import { getCollection } from 'astro:content';

// Get featured projects (you can add a 'featured' field to frontmatter)
const projects = await getCollection('projects');
const featuredProjects = projects
  .filter(p => p.data.featured)
  .slice(0, 3);
---

<BaseLayout>
  <section class="hero">
    <!-- Featured Images - Static background -->
    <div class="hero-images">
      <img src="/Website/images/hero-bg.jpg" alt="Hero Background" class="hero-bg-image" />
    </div>
    
    <div class="hero-content">
      <!-- Name with elegant spacing -->
      <h1 class="hero-name">
        <span class="name-first"><em>rhythm</em></span>
        <span class="name-last">rastogi</span>
      </h1>
      
      <!-- Tagline -->
      <p class="hero-tagline">{site.tagline}</p>
      
      <!-- Location -->
      <p class="hero-location">{site.location}</p>
      
      <!-- Social Links -->
      <div class="hero-social">
        <a href="mailto:rastogirhythm00@gmail.com" class="social-link">email↗</a>
        {site.social.map(({ label, url }) => (
          <a href={url} target="_blank" rel="noopener noreferrer" class="social-link">{label}↗</a>
        ))}
      </div>
    </div>
  </section>
  
</BaseLayout>

<style>
  @font-face {
    font-family: 'FrauncesRoman';
    src: url('/Website/fonts/Fraunces/Fraunces-VariableFont_SOFT,WONK,opsz,wght.ttf') format('truetype');
  }

  @font-face {
    font-family: 'FrauncesItalic';
    src: url('/Website/fonts/Fraunces/Fraunces-Italic-VariableFont_SOFT,WONK,opsz,wght.ttf') format('truetype');
  }

  /* Hero Section */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    padding: var(--space-3xl) var(--space-2xl) var(--space-ul);
    align-items: center;
  }
  
  .hero-content {
    max-width: 480px;
    margin-left: auto;
  }
  
  .hero-name {
    font-size: 4.5rem;
    line-height: 0.78;
    margin-bottom: 0.75rem;
    margin-top: 0;
    letter-spacing: -0.01em;
  }
  
  .name-first {
    display: block;
    font-family: 'FrauncesItalic', serif;
    font-weight: 350;
    letter-spacing: -0.02em;
  }
  
  .name-last {
    display: block;
    font-family: 'FrauncesRoman', serif;
    letter-spacing: -0.02em;
    font-weight: 350;
  }
  
  .hero-tagline {
    font-size: var(--text-base);
    color: #666666;
    max-width: 380px;
    line-height: 1.6;
    margin-bottom: 1rem;
  }
  
  .hero-location {
    font-size: var(--text-sm);
    color: #666666;
    letter-spacing: 0.02em;
    margin-bottom: var(--space-md);
  }
  
  .hero-social {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-top: 1.875rem;
  }
  
  .social-link {
    font-size: var(--text-sm);
    color: #666666;
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  
  .social-link:hover {
    color: var(--color-accent);
  }
  
  /* Floating Images */
  .hero-images {
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  
  .hero-bg-image {
    width: 100%;
    height: auto;
    object-fit: contain;
    border-radius: 4px;
    max-width: 110%;
    transform-origin: 30% 35%;
    transition: transform 800ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  
  .hero-bg-image:hover {
    transform: scale(1.25);
  }
  
  /* Intro Section */
  .intro {
    padding: var(--space-3xl) var(--space-2xl);
    border-top: 1px solid var(--color-border);
  }
  
  .intro-content {
    max-width: var(--content-width);
    margin: 0 auto;
    text-align: center;
  }
  
  .intro-text {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }
  
  .intro-links {
    display: flex;
    justify-content: center;
    gap: var(--space-lg);
  }
  
  .link {
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid var(--color-text);
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }
  
  .link:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
  
  /* Mobile */
  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
      padding: var(--space-2xl) var(--space-lg) var(--space-xl);
      min-height: auto;
    }
    
    .hero-content {
      max-width: 100%;
      text-align: center;
      margin: 0 auto;
      order: -1;
    }
    
    .hero-tagline {
      margin: 0 auto var(--space-md);
    }
    
    .hero-images {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-md);
    }
    
    .pos-3 {
      grid-column: span 2;
      max-width: 60%;
      margin: 0 auto;
    }
    
    .intro {
      padding: var(--space-3xl) var(--space-lg);
    }
  }
  
  @media (max-width: 640px) {
    .hero-name {
      font-size: var(--text-3xl);
    }
    
    .hero-images {
      grid-template-columns: 1fr;
    }
    
    .pos-3 {
      grid-column: span 1;
      max-width: 100%;
    }
  }
</style>
