---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';
---

<BaseLayout title="About">
  <section class="about">
    <div class="about-header">
      <h1 class="about-title">About</h1>
    </div>
    
    <div class="about-content">
      <div class="about-main">
        <!-- Portrait placeholder -->
        <div class="about-portrait">
          <div class="portrait-image">
            <!-- Add your photo here -->
            <div class="placeholder">Photo</div>
          </div>
        </div>
        
        <div class="about-text">
          <p class="about-intro">
            {site.bio}
          </p>
          
          <div class="education-section">
            <h3 class="education-title">Education</h3>
            <div class="education-item">
              <p class="education-degree">BA Honors Sociology</p>
              <p class="education-school">Brown University, USA</p>
              <p class="education-years">2018-2022.5</p>
            </div>
          </div>
          
          <a href="/Website/pdfs/resume.pdf" target="_blank" rel="noopener noreferrer" class="resume-button">
            Download Resume
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about {
    padding: var(--space-3xl) var(--space-lg) var(--space-2xl);
  }
  
  .about-header {
    max-width: var(--max-width);
    margin: 0 auto var(--space-2xl);
  }
  
  @font-face {
    font-family: 'FrauncesItalic';
    src: url('/Website/fonts/Fraunces/Fraunces-Italic-VariableFont_SOFT,WONK,opsz,wght.ttf') format('truetype');
  }

  @font-face {
    font-family: 'FrauncesRoman';
    src: url('/Website/fonts/Fraunces/Fraunces-VariableFont_SOFT,WONK,opsz,wght.ttf') format('truetype');
  }

  .about-title {
    font-size: var(--text-3xl);
    font-style: italic;
    font-family: 'FrauncesItalic';
  }
  
  .about-content {
    max-width: var(--max-width);
    margin: 0 auto;
  }
  
  .about-main {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: var(--space-2xl);
    align-items: start;
  }
  
  .about-portrait {
    position: sticky;
    top: var(--space-3xl);
  }
  
  .portrait-image {
    aspect-ratio: 3/4;
    background: var(--color-bg-alt);
    border-radius: 2px;
    overflow: hidden;
  }
  
  .portrait-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-subtle);
    font-size: var(--text-sm);
    border: 1px dashed var(--color-border);
  }
  
  .about-text {
    max-width: 600px;
  }
  
  .education-section {
    margin-bottom: var(--space-xl);
  }
  
  .education-title {
    font-family: var(--font-serif);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: var(--space-md);
    color: var(--color-text-subtle);
  }
  
  .education-item {
    margin-bottom: var(--space-md);
  }
  
  .education-degree {
    font-family: var(--font-serif);
    font-size: var(--text-base);
    color: var(--color-text);
    margin: 0 0 0.25rem 0;
    line-height: 1.4;
  }
  
  .education-school {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin: 0 0 0.25rem 0;
  }
  
  .education-years {
    font-size: var(--text-xs);
    color: var(--color-text-subtle);
    margin: 0;
  }
  
  .about-intro {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    line-height: 1.6;
    margin-bottom: var(--space-xl);
    color: var(--color-text-muted);
  }
  
  .resume-button {
    display: inline-block;
    padding: 0.625rem 1.25rem;
    background-color: transparent;
    color: var(--color-text);
    text-decoration: none;
    border: 1.5px solid var(--color-text);
    border-radius: 2px;
    font-size: var(--text-sm);
    font-family: var(--font-serif);
    letter-spacing: 0.025em;
    transition: all var(--transition-base);
    position: relative;
  }
  
  .resume-button:hover {
    background-color: var(--color-text);
    color: white;
    border-color: var(--color-text);
  }
  
  .about-details {
    display: grid;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--color-border);
  }
  
  .detail-block {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: var(--space-md);
  }
  
  .detail-label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-subtle);
    font-family: var(--font-sans);
    font-weight: 500;
  }
  
  .detail-block p {
    margin: 0;
    font-size: var(--text-sm);
  }
  
  .about-extended {
    margin-bottom: var(--space-xl);
  }
  
  .about-extended p {
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }
  
  .about-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-lg);
  }
  
  /* Mobile */
  @media (max-width: 900px) {
    .about-main {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
    
    .about-portrait {
      position: static;
      max-width: 300px;
    }
    
    .detail-block {
      grid-template-columns: 1fr;
      gap: var(--space-xs);
    }
  }
</style>
