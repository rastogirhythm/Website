---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';
---

<BaseLayout title="About">
  <section class="about">
    <div class="about-header">
      <h1 class="about-title">About</h1>
    </div>
    
    <div class="about-content">
      <div class="about-main">
        <!-- Portrait -->
        <div class="about-portrait">
          <div class="portrait-image">
            <img src="/Website/images/about.jpeg" alt="Rhythm Rastogi portrait" />
          </div>
        </div>
        
        <div class="about-text">
          <div class="bio-section">
            <p class="about-intro">
              I am a design researcher working across social impact, climate initiatives, and community-led projects. My approach is qualitative, conceptual, and interdisciplinary, drawing from natural patterns, regenerative design, and creative processes.
            </p>

            <p class="about-intro">
              Trained in Sociology and Urban Studies at Brown University, I work through field research, participatory methods, and facilitation to understand how people relate to nature, livelihoods, and one another. My practice has taken shape across academia, grassroots movements, and nonprofit spaces, and more recently through curating and creating experiences that experiment with alternative ways of researching and sense-making together.
            </p>

            <p class="about-intro">
              Alongside this, I ground my work in material and ecological practice to incorporate ideas of regeneration in everyday life. I've grown pocket forests and a community greenspace in Baroda-Savitri Urban Food Forest. My honors thesis also explored ecological networks as a way of thinking about community ecosystems.
            </p>
          </div>
          
          <div class="education-section">
            <h3 class="education-title">Education</h3>
            <div class="education-item">
              <p class="education-degree">Bachelor of Arts (Honors) Sociology</p>
              <p class="education-school">Brown University, USA</p>
              <p class="education-years">2018-2022.5</p>
            </div>
          </div>
          
          <div class="cta-section">
            <a href="/Website/pdfs/resume.pdf" target="_blank" rel="noopener noreferrer" class="resume-button">
              Download Resume
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about {
    padding: var(--space-3xl) var(--space-lg) var(--space-2xl);
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    max-width: var(--max-width);
    margin: 0 auto;
  }
  
  .about-header {
    margin-bottom: var(--space-2xl);
  }
  
  @font-face {
    font-family: 'FrauncesItalic';
    src: url('/Website/fonts/Fraunces/Fraunces-Italic-VariableFont_SOFT,WONK,opsz,wght.ttf') format('truetype');
  }

  @font-face {
    font-family: 'FrauncesRoman';
    src: url('/Website/fonts/Fraunces/Fraunces-VariableFont_SOFT,WONK,opsz,wght.ttf') format('truetype');
  }

  .about-title {
    font-size: var(--text-3xl);
    font-style: italic;
    font-family: 'FrauncesItalic';
  }
  
  .about-content {
    flex: 1;
  }
  
  .about-main {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--space-lg);
    align-items: start;
  }

  .about-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 40px;
  }
  
  .bio-section {
    margin-bottom: var(--space-lg);
    padding-bottom: 0;
    border-bottom: none;
  }

  .bio-section .about-intro:last-child {
    margin-bottom: 0;
  }
  
  .about-portrait {
    position: static;
    height: auto;
    margin-top: var(--space-lg);
  }
  
  .portrait-image {
    aspect-ratio: 3/4;
    background: var(--color-bg-alt);
    border-radius: 2px;
    overflow: hidden;
    width: 100%;
    max-width: 280px;
  }
  
  .portrait-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-subtle);
    font-size: var(--text-sm);
    border: 1px dashed var(--color-border);
  }
  
  .about-text {
    max-width: 100%;
    padding-top: 0;
    display: flex;
    flex-direction: column;
  }
  
  .education-section {
    margin-bottom: var(--space-md);
    padding-bottom: 0;
    border-bottom: none;
  }
  
  .education-title {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }
  
  .education-item {
    margin-bottom: 0;
  }
  
  .education-degree {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text);
    margin: 0 0 0.2rem 0;
    line-height: 1.3;
  }
  
  .education-school {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 0.8rem;
    font-weight: 400;
    color: #666666;
    margin: 0 0 0.1rem 0;
  }
  
  .education-years {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 0.8rem;
    font-weight: 400;
    color: #666666;
    margin: 0;
  }

  .cta-section {
    margin-top: var(--space-sm);
  }
  
  .about-intro {
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.6;
    margin-bottom: 0.6rem;
    color: var(--color-text);
    text-align: left;
  }
  
  .resume-button {
    display: inline-block;
    padding: 0.625rem 1.25rem;
    background-color: transparent;
    color: var(--color-text);
    text-decoration: none;
    border: 1.5px solid var(--color-text);
    border-radius: 2px;
    font-family: 'Hanken Grotesk', sans-serif;
    font-size: var(--text-sm);
    letter-spacing: 0.025em;
    transition: all var(--transition-base);
    position: relative;
  }
  
  .resume-button:hover {
    background-color: var(--color-text);
    color: white;
    border-color: var(--color-text);
  }
  
  .about-details {
    display: grid;
    gap: var(--space-md);
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--color-border);
  }
  
  .detail-block {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: var(--space-md);
  }
  
  .detail-label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-subtle);
    font-family: var(--font-sans);
    font-weight: 500;
  }
  
  .detail-block p {
    margin: 0;
    font-size: var(--text-sm);
  }
  
  .about-extended {
    margin-bottom: var(--space-xl);
  }
  
  .about-extended p {
    color: var(--color-text-muted);
    margin-bottom: var(--space-md);
  }
  
  .about-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-lg);
  }
  
  /* Mobile */
  @media (max-width: 900px) {
    .about-main {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }
    
    .about-portrait {
      position: static;
      max-width: 300px;
    }
    
    .detail-block {
      grid-template-columns: 1fr;
      gap: var(--space-xs);
    }
  }
</style>
