---
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL;

const links = [
  { href: `${base}/about`, label: 'about' },
  { href: `${base}/projects`, label: 'projects' },
  { href: `${base}/sandbox`, label: 'sandbox' },
];
---

<nav class="nav">
  <a href={base} class="nav-logo">
    <span class="logo-text">RR</span>
  </a>
  
  <div class="nav-links">
    {links.map(({ href, label }) => (
      <a 
        href={href} 
        class:list={['nav-link', { active: currentPath.startsWith(href) }]}
      >
        {label}
      </a>
    ))}
  </div>
</nav>

<style>
  @font-face {
    font-family: 'FrauncesRoman';
    src: url('/Website/fonts/Fraunces/Fraunces-VariableFont_SOFT,WONK,opsz,wght.ttf') format('truetype');
  }

  @font-face {
    font-family: 'FrauncesItalic';
    src: url('/Website/fonts/Fraunces/Fraunces-Italic-VariableFont_SOFT,WONK,opsz,wght.ttf') format('truetype');
  }

  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: flex-end;
    align-items: flex-start;
    padding: var(--space-lg) var(--space-2xl) var(--space-md);
    z-index: 100;
    mix-blend-mode: difference;
  }
  
  .nav-logo {
    position: absolute;
    left: var(--space-2xl);
  }
  
  .nav-logo {
    font-family: 'FrauncesItalic', serif;
    font-size: 1.2rem;
    color: white;
    text-decoration: none;
    font-weight: 400;
    transition: opacity var(--transition-fast);
  }
  
  .nav-logo:hover {
    opacity: 0.7;
  }
  
  .logo-text {
    letter-spacing: -0.08em;
  }
  
  .nav-links {
    display: flex;
    gap: var(--space-lg);
  }
  
  .nav-link {
    font-size: var(--text-sm);
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color var(--transition-fast);
    letter-spacing: 0.02em;
  }
  
  .nav-link:hover,
  .nav-link.active {
    color: white;
  }
  
  /* Mobile */
  @media (max-width: 640px) {
    .nav {
      padding: var(--space-sm) var(--space-md);
    }
    
    .nav-links {
      gap: var(--space-md);
    }
    
    .nav-link {
      font-size: var(--text-xs);
    }
  }
</style>
