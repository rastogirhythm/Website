---
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL;

const links = [
  { href: `${base}/about`, label: 'about' },
  { href: `${base}/projects`, label: 'projects' },
  { href: `${base}/sandbox`, label: 'sandbox' },
];
---

<nav class="nav">
  <a href={base} class="nav-logo">
    <svg class="spiral-icon" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
      <path d="M 50 2 Q 95 2, 98 50 Q 98 95, 50 98 Q 5 98, 2 50 Q 2 8, 42 5 Q 85 5, 88 50 Q 88 92, 50 92 Q 12 92, 12 50 Q 12 22, 40 20 Q 78 20, 80 50 Q 80 88, 50 88 Q 18 88, 18 50 Q 18 28, 38 26 Q 72 26, 74 50 Q 74 84, 50 84 Q 22 84, 22 50 Q 22 32, 36 30 Q 68 30, 70 50 Q 70 80, 50 80 Q 26 80, 26 50 Q 26 35, 34 34 Q 65 34, 66 50 Q 66 78, 50 78 Q 28 78, 28 50" 
            fill="none" 
            stroke="currentColor" 
            stroke-width="1.6" 
            stroke-linecap="round"/>
    </svg>
  </a>
  
  <div class="nav-links">
    {links.map(({ href, label }) => (
      <a 
        href={href} 
        class:list={['nav-link', { active: currentPath.startsWith(href) }]}
      >
        {label}
      </a>
    ))}
  </div>
</nav>

<style>
  @font-face {
    font-family: 'FrauncesRoman';
    src: url('/Website/fonts/Fraunces/Fraunces-VariableFont_SOFT,WONK,opsz,wght.ttf') format('truetype');
  }

  @font-face {
    font-family: 'FrauncesItalic';
    src: url('/Website/fonts/Fraunces/Fraunces-Italic-VariableFont_SOFT,WONK,opsz,wght.ttf') format('truetype');
  }

  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    justify-content: flex-end;
    align-items: flex-start;
    padding: var(--space-lg) var(--space-2xl) var(--space-md);
    z-index: 100;
  }
  
  .nav-logo {
    position: absolute;
    left: var(--space-2xl);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 45px;
    height: 45px;
    color: #4a4a4a;
    text-decoration: none;
    transition: opacity var(--transition-fast);
    top: 50%;
    transform: translateY(-50%);
  }
  
  .nav-logo:hover {
    opacity: 0.7;
  }
  
  .spiral-icon {
    width: 36px;
    height: 36px;
    transition: transform 600ms ease-in-out;
  }
  
  .nav-logo:hover .spiral-icon {
    transform: rotate(180deg);
  }
  
  .logo-text {
    letter-spacing: -0.08em;
  }
  
  .nav-links {
    display: flex;
    gap: var(--space-lg);
  }
  
  .nav-link {
    font-size: var(--text-sm);
    color: #4a4a4a;
    text-decoration: none;
    transition: color var(--transition-fast);
    letter-spacing: 0.02em;
  }
  
  .nav-link:hover,
  .nav-link.active {
    color: #5a7366;
  }
  
  /* Mobile */
  @media (max-width: 640px) {
    .nav {
      padding: var(--space-sm) var(--space-md);
    }
    
    .nav-links {
      gap: var(--space-md);
    }
    
    .nav-link {
      font-size: var(--text-xs);
    }
  }
</style>
